# ============================================================
# Sakhi — Environment Variable Template
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&tls=true
MONGODB_DB_NAME=sakhi

# --- Grok / xAI ---
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_MODEL=grok-3-latest
GROK_TIMEOUT_SECONDS=15.0
GROK_MAX_TOKENS=512

# --- Cycle defaults ---
DEFAULT_CYCLE_LENGTH_DAYS=28
